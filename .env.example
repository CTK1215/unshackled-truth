# ============================================================================
#  Unshackled Truth — environment variables
# ============================================================================
#  Copy this file to ".env.local" and fill in the values you have. Every one is
#  OPTIONAL — the site runs fine with none of them set (using sample content and
#  the Amazon buy link). Turn on each feature by adding its keys. See the README
#  section "Turning on the services" for step-by-step instructions.
# ============================================================================

# ---- CMS dashboard (Sanity) -------------------------------------------------
# Get these by running `npx sanity init` in this folder (free account).
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-10-01

# ---- Speaking form email (Resend) -------------------------------------------
# Free at resend.com. Without this, form submissions are logged to the server
# console instead of emailed.
RESEND_API_KEY=
# The "from" address. Until you verify your own domain in Resend, you can use
# the shared testing sender below.
RESEND_FROM="Unshackled Truth <onboarding@resend.dev>"

# ---- Direct eBook sales (Stripe) --------------------------------------------
# From dashboard.stripe.com (use a test key like sk_test_... first).
STRIPE_SECRET_KEY=

# ---- Site URL (optional) ----------------------------------------------------
# Used to build Stripe success/cancel links. Defaults to the current origin.
NEXT_PUBLIC_SITE_URL=
